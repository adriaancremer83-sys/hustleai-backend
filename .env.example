# ═══════════════════════════════════════
# HustleAI — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ═══════════════════════════════════════

# Supabase (get from supabase.com → project → settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anthropic (get from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Payfast (get from payfast.co.za → account → integration)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=true   # Change to false when going live

# URLs (update after deployment)
FRONTEND_URL=https://your-site.netlify.app
BACKEND_URL=https://your-backend.railway.app

# Admin (set a strong password — this is your dashboard login)
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SECRET_KEY=choose-a-long-random-string-for-jwt

# CORS (your frontend domain)
ALLOWED_ORIGIN=https://your-site.netlify.app

# Server
PORT=3000
